# ========================================
# SERVER CONFIGURATION
# ========================================
BACKEND_PORT=3001
FRONTEND_PORT=5173
NODE_ENV=development

# ========================================
# API CONFIGURATION
# ========================================
# Frontend to Backend API URL
VITE_API_BASE_URL=http://127.0.0.1:3001/api

# ========================================
# PAPERCUT MF CONFIGURATION
# ========================================
PAPERCUT_URL=http://papercut.example.com:9191
PAPERCUT_API_TOKEN=YOUR_API_TOKEN
PAPERCUT_TIMEOUT=30000

# ========================================
# SMTP EMAIL CONFIGURATION
# ========================================
SMTP_SERVER=smtp.example.com
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=false
DEFAULT_FROM_EMAIL=printer-monitor@example.com
DEFAULT_TO_EMAIL=

# ========================================
# AUTHENTICATION CONFIGURATION
# ========================================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=7d
SESSION_SECRET=your-session-secret-change-in-production

# ========================================
# DATABASE CONFIGURATION (Future)
# ========================================
DB_TYPE=sqlite
DB_PATH=./data/printers.db
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=printer_db
# DB_USER=printer_user
# DB_PASSWORD=

# ========================================
# LICENSE CONFIGURATION
# ========================================
LICENSE_EXPIRATION_DATE=2026-12-31

# ========================================
# LOGGING CONFIGURATION
# ========================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ========================================
# SECURITY CONFIGURATION
# ========================================
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
