// Get system settings
router.get('/settings', (req, res) => {
  console.log('System settings request received:', new Date().toISOString());
  console.log('Request method:', req.method);
  console.log('Request URL:', req.originalUrl);
  console.log('Response data:', systemSettings);
  res.json(systemSettings);
});

// Save system settings
router.post('/settings', (req, res) => {
  try {
    // Save settings using settings service
    systemSettings = settingsService.saveSettings(req.body);
    
    // Recreate email service with updated settings
    emailService = createEmailService();
    console.log('Email service reinitialized with updated settings');
    
    res.json({ message: 'Settings saved and persisted', settings: systemSettings });
  } catch (error) {
    console.error('Error saving settings:', error.message);
    res.status(500).json({ message: 'Failed to save settings', error: error.message });
  }
});

// Test email sending endpoint
router.get('/test-email', async (req, res) => {
  try {
    const { to, from } = req.query;
    
    // Validate required parameters
    if (!to) {
      return res.status(400).json({ message: 'Recipient email is required' });
    }
    
    // Use default from email if not provided
    const fromEmail = from || process.env.DEFAULT_FROM_EMAIL || 'printer-report@example.com';
    
    console.log('Testing email sending:');
    console.log('- From:', fromEmail);
    console.log('- To:', to);
    
    // Get actual remaining license days and expiration date
    const actualLicenseDays = printerService.getLicenseRemainingDays();
    const licenseExpirationDate = settingsService.getLicenseExpirationDate();
    
    console.log('Using actual license remaining days:', actualLicenseDays);
    console.log('Using actual license expiration date:', licenseExpirationDate);
    
    // 修复：调整参数格式以匹配emailService.sendWeeklyReport的定义
    const testPrinters = [{ name: 'Test Printer', ip: '127.0.0.1', status: 'online', tonerLevels: { black: 100, cyan: 100, magenta: 100, yellow: 100 } }];
    const emailData = {
      startDate: '2023-01-01',
      endDate: '2023-01-07',
      toEmail: to,
      fromEmail: fromEmail
    };
    
    const testResult = await emailService.sendWeeklyReport(testPrinters, actualLicenseDays, emailData);
    
    res.json(testResult);
  } catch (error) {
    console.error('Error testing email:', error);
    res.status(500).json({ message: 'Failed to test email', error: error.message });
  }
});

// Generate and send weekly report
router.post('/generate-report', async (req, res) => {
  try {
    const { startDate, endDate, toEmail, fromEmail, ccEmail, manualData, reportHtml } = req.body;

    // Calculate default weekly report period (last week)
    const defaultEndDate = addDays(new Date(), -1);
    const defaultStartDate = addDays(defaultEndDate, -6);

    // Format dates
    const reportStartDate = startDate || format(defaultStartDate, 'yyyy-MM-dd');
    const reportEndDate = endDate || format(defaultEndDate, 'yyyy-MM-dd');

    // Get all printer statuses
    let printersStatus = [];
    if (manualData && manualData.length > 0) {
      // Use manually input data
      printersStatus = manualData;
    } else {
      // Auto fetch data
      const statusPromises = printerConfigs.map(async (printer) => {
        try {
          // 尝试使用常规的API方式获取状态
          let status = await printerService.getPrinterStatus(printer, systemSettings.papercut);
          
          // 检查是否是北京的打印机，或者是否需要使用网页抓取方式获取墨粉数据
          const isBeijingPrinter = printer.name.includes('Beijing');
          
          // 首先尝试使用改进的网页抓取方式获取墨粉数据（适用于所有打印机）
          try {
            console.log(`Using enhanced web scraping method for printer ${printer.name} (IP: ${printer.ip})`);
            // 使用我们修改的printerScraper.js中的网页抓取函数
            const webpageTonerData = await printerScraper.scrapePrinterTonerData(printer.ip);
            
            // 只有当网页抓取返回了有效数据时才更新
            if (webpageTonerData && (webpageTonerData.black > 0 || webpageTonerData.cyan > 0 || 
                                   webpageTonerData.magenta > 0 || webpageTonerData.yellow > 0)) {
              status.tonerLevels = webpageTonerData;
              status.source = 'webpage (enhanced scraping)';
              console.log(`Successfully updated ${printer.name} status with enhanced webpage data`);
            }
          } catch (scrapingError) {
            console.warn(`Web scraping method failed for ${printer.name}:`, scrapingError.message);
            // 网页抓取失败后，如果是北京的打印机或者墨粉数据仍无效，尝试使用OCR方式
            if (isBeijingPrinter || !status.tonerLevels || Object.keys(status.tonerLevels).length === 0) {
              try {
                console.log(`Using screenshot OCR method for printer ${printer.name} (IP: ${printer.ip})`);
                const screenshotOcrService = require('../services/screenshotOcrService');
                const ocrTonerData = await screenshotOcrService.getTonerDataWithScreenshotOcr(printer.ip);
                
                // 合并OCR获取的墨粉数据
                status.tonerLevels = ocrTonerData;
                status.source = 'webpage (screenshot OCR)';
                console.log(`Successfully updated ${printer.name} status with OCR data`);
              } catch (ocrError) {
                console.warn(`OCR method also failed for ${printer.name}:`, ocrError.message);
                // OCR失败也不要覆盖已有的数据
              }
            }
          }
          
          return status;
        } catch (error) {
          console.error(`Error getting status for printer ${printer.name}:`, error);
          return {
            ...printer,
            ...printerService.getDefaultStatus(printer.ip)
          };
        }
      });
      printersStatus = await Promise.all(statusPromises);
    }

    // Get remaining license days
    const licenseDays = printerService.getLicenseRemainingDays();
    
    // Prepare email data with ccEmail and frontend generated HTML
    const emailData = {
      startDate: reportStartDate,
      endDate: reportEndDate,
      toEmail,
      fromEmail,
      ccEmail,
      reportHtml // 包含前端生成的HTML内容，确保邮件与预览一致
    };

    // Generate and send report with new method signature
    // 如果提供了前端生成的HTML，则直接使用它
    if (emailData.reportHtml) {
      console.log('Using frontend generated HTML for email');
      const result = await emailService.sendWeeklyReportWithCustomHtml(emailData.reportHtml, emailData);
      res.json(result);
    } else {
      // 回退到后端生成HTML的方式
      const result = await emailService.sendWeeklyReport(printersStatus, licenseDays, emailData);
      res.json(result);
    }
  } catch (error) {
    console.error('Error generating report:', error);
    res.status(500).json({ message: 'Failed to generate report', error: error.message });
  }
});

// Add printer screenshot OCR routes
router.get('/printers/scrape/printer/:ip/toner/screenshot', async (req, res) => {
  try {
    const { ip } = req.params;
    console.log(`Fetching printer toner data via screenshot OCR for IP: ${ip}`);
    
    // 使用screenshotOcrService获取墨粉数据
    const screenshotOcrService = require('../services/screenshotOcrService');
    const tonerData = await screenshotOcrService.getTonerDataWithScreenshotOcr(ip);
    
    res.json({
      success: true,
      data: tonerData,
      source: 'webpage (screenshot OCR)'
    });
  } catch (error) {
    console.error(`Error fetching printer data via screenshot OCR:`, error);
    res.status(500).json({
      success: false,
      error: error.message || 'Failed to fetch printer data'
    });
  }
});

// Get remaining license days API
router.get('/license-days', (req, res) => {
  try {
    console.log('###########################################');
    console.log('## License days request received:', new Date().toISOString());
    console.log('## Request method:', req.method);
    console.log('## Request URL:', req.originalUrl);
    
    // Directly calculate license days here for debugging
    const settingsService = require('../services/settingsService');
    const expirationDateStr = settingsService.getLicenseExpirationDate();
    const expirationDate = new Date(expirationDateStr);
    const today = new Date();
    const diffTime = expirationDate - today;
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    const licenseDays = Math.max(diffDays, 0);
    
    console.log('## Using expiration date:', expirationDateStr);
    console.log('## Current date:', today.toISOString());
    console.log('## Calculated remaining days:', licenseDays);
    console.log('###########################################');
    
    res.json({ remainingDays: licenseDays });
  } catch (error) {
    console.error('###########################################');
    console.error('## Error calculating license days:', error);
    console.error('###########################################');
    res.status(500).json({ message: 'Failed to calculate license days', error: error.message });
  }
});

