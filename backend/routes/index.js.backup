const express = require('express');
const router = express.Router();
const printerService = require('../services/printerService');
const EmailServiceClass = require('../services/emailService');
const { format, addDays, differenceInDays } = require('date-fns');
const fs = require('fs');
const path = require('path');
const settingsService = require('../services/settingsService');
const PRINTERS_FILE = path.join(__dirname, '../config/printers.json');

// Import printer scraper router and functions
const printerScraper = require('../printerScraper');
// Use the printer scraper router for toner data endpoints
router.use('/', printerScraper.router);

// Ensure printer config file directory exists
const printersDir = path.dirname(PRINTERS_FILE);
if (!fs.existsSync(printersDir)) {
  fs.mkdirSync(printersDir, { recursive: true });
}

// Load system settings from settings service
let systemSettings = settingsService.getSettings();

// Create email service with system settings
let emailService;
function createEmailService() {
  // Ensure systemSettings is loaded before creating email service
  if (systemSettings && systemSettings.email) {
    // Convert system settings format to email service format
    const emailConfig = {
      host: systemSettings.email.smtpServer,
      port: systemSettings.email.smtpPort,
      secure: systemSettings.email.useTls,
      user: systemSettings.email.smtpUser,
      pass: systemSettings.email.smtpPass
    };
    return new EmailServiceClass(emailConfig);
  }
  return new EmailServiceClass(); // Fallback to default if settings not available
}

// Initialize email service with loaded settings
emailService = createEmailService();
console.log('Email service initialized with settings:', emailService);




// Load printer configs from file
let printerConfigs;
if (fs.existsSync(PRINTERS_FILE)) {
  try {
    printerConfigs = JSON.parse(fs.readFileSync(PRINTERS_FILE, 'utf8'));
  } catch (error) {
    console.error('Error loading printers file:', error.message);
    printerConfigs = [
      { name: 'Beijing_12A', ip: '10.128.20.6' },
      { name: 'Beijing_12B', ip: '10.128.21.6' },
      { name: 'Shanghai_26A', ip: '10.132.20.6' },
      { name: 'Shenzhen_18F', ip: '10.136.9.6' }
    ];
  }
} else {
  // Initialize with default printers when file doesn't exist
  printerConfigs = [
    { name: 'Beijing_12A', ip: '10.128.20.6' },
    { name: 'Beijing_12B', ip: '10.128.21.6' },
    { name: 'Shanghai_26A', ip: '10.132.20.6' },
    { name: 'Shenzhen_18F', ip: '10.136.9.6' }
  ];
  try {
    fs.writeFileSync(PRINTERS_FILE, JSON.stringify(printerConfigs, null, 2), 'utf8');
  } catch (error) {
      console.error('Error creating initial printers file:', error.message);
    }
  }

  // Get all printer configurations
  router.get('/printers', (req, res) => {
    res.json(printerConfigs);
  });

  // Save all printers (bulk save endpoint)
  router.post('/printers/save', (req, res) => {
    try {
      const { printers } = req.body;
      
      if (!Array.isArray(printers)) {
        return res.status(400).json({ error: 'Printers must be an array' });
      }
      
      console.log(`Received request to save ${printers.length} printers`);
      
      // Update printer configurations
      printerConfigs = printers.map(printer => ({
        id: printer.id || Date.now().toString(),
        name: printer.name,
        ip: printer.ip,
        serialNumber: printer.serialNumber || '',
        port: printer.port || '',
        macAddress: printer.macAddress || '',
        location: printer.location || '',
        assetTag: printer.assetTag || '',
        model: printer.model || '',
        status: printer.status || 'unknown',
        manualTonerLevels: printer.manualTonerLevels || {},
        lastUpdated: new Date().toISOString()
      }));
      
      // Write to file
      fs.writeFileSync(PRINTERS_FILE, JSON.stringify(printerConfigs, null, 2), 'utf8');
      
      // Also update the frontend printers-data.json file for consistency
      const frontendPrintersFile = path.join(__dirname, '../../printers-data.json');
      fs.writeFileSync(frontendPrintersFile, JSON.stringify(printerConfigs, null, 2), 'utf8');
      
      console.log(`Successfully saved ${printerConfigs.length} printers to both backend and frontend files`);
      res.json({ message: 'Printers saved successfully', count: printerConfigs.length });
    } catch (error) {
      console.error('Error saving printers:', error.message);
      res.status(500).json({ error: 'Failed to save printers', details: error.message });
    }
  });

  // Update printer status
  router.post('/printers/:id/status', (req, res) => {
    const printerId = req.params.id;
    const { status } = req.body;
    
    const printer = printerConfigs.find(p => p.id === printerId);
    if (!printer) {
      return res.status(404).json({ error: 'Printer not found' });
    }
    
    printer.status = status;
    printer.lastUpdated = new Date().toISOString();
    
    try {
      fs.writeFileSync(PRINTERS_FILE, JSON.stringify(printerConfigs, null, 2), 'utf8');
      res.json(printer);
    } catch (error) {
      console.error('Error updating printer status:', error.message);
      res.status(500).json({ error: 'Failed to update printer status' });
    }
  });

  // Add printer configuration
  router.post('/printers', (req, res) => {
    const { name, ip } = req.body;
    if (!name || !ip) {
      return res.status(400).json({ error: 'Name and IP are required' });
    }

    // Check if exists
    const existing = printerConfigs.find(p => p.ip === ip);
    if (existing) {
      return res.status(409).json({ error: 'Printer with this IP already exists' });
    }

    const newPrinter = {
      id: Date.now().toString(),
      name,
      ip,
      status: 'unknown',
      lastUpdated: new Date().toISOString()
    };

    printerConfigs.push(newPrinter);

    try {
      fs.writeFileSync(PRINTERS_FILE, JSON.stringify(printerConfigs, null, 2), 'utf8');
      res.status(201).json(newPrinter);
    } catch (error) {
      console.error('Error adding printer:', error.message);
      res.status(500).json({ error: 'Failed to add printer' });
    }
  });

  // Get printer status via SNMP
  router.get('/printers/:ip/snmp', async (req, res) => {
    const { ip } = req.params;
    const { community = 'public' } = req.query;
    
    if (!ip) {
      return res.status(400).json({ error: 'Printer IP is required' });
    }
    
    try {
      const status = await printerService.getPrinterStatusViaSnmp(ip, community);
      res.json(status);
    } catch (error) {
      console.error('Error getting printer status via SNMP:', error.message);
      res.status(500).json({ error: 'Failed to get printer status via SNMP', details: error.message });
    }
  });

  // Update printer configuration
  router.put('/printers/:id', (req, res) => {
    const printerId = req.params.id;
    console.log('Received update request for printer ID:', printerId);
    console.log('Received data:', req.body);
    const { name, ip, serialNumber, port, location, macAddress, assetTag, model, manualTonerLevels } = req.body;
    console.log('Extracted fields:', { name, ip, serialNumber, port, location, macAddress, assetTag, model, manualTonerLevels });
    if (!name || !ip) {
      return res.status(400).json({ error: 'Name and IP are required' });
    }

    const printerIndex = printerConfigs.findIndex(p => p.id === printerId);
    if (printerIndex === -1) {
      return res.status(404).json({ error: 'Printer not found' });
    }

    // Check if IP is used by another printer
    const ipExists = printerConfigs.some((p, index) => index !== printerIndex && p.ip === ip);
    if (ipExists) {
      return res.status(409).json({ error: 'Printer with this IP already exists' });
    }

    printerConfigs[printerIndex] = {
      ...printerConfigs[printerIndex],
      name,
      ip,
      serialNumber,
      port,
      location,
      macAddress,
      assetTag,
      model,
      manualTonerLevels,
      lastUpdated: new Date().toISOString()
    };

    console.log('Updated printer config:', printerConfigs[printerIndex]);

    try {
      fs.writeFileSync(PRINTERS_FILE, JSON.stringify(printerConfigs, null, 2), 'utf8');
      res.json(printerConfigs[printerIndex]);
    } catch (error) {
      console.error('Error updating printer:', error.message);
      res.status(500).json({ error: 'Failed to update printer' });
    }
  });

  // Delete printer configuration
  router.delete('/printers/:id', (req, res) => {
    const printerId = req.params.id;
    const initialLength = printerConfigs.length;
    printerConfigs = printerConfigs.filter(p => p.id !== printerId);

    if (printerConfigs.length === initialLength) {
      return res.status(404).json({ error: 'Printer not found' });
    }

    try {
      fs.writeFileSync(PRINTERS_FILE, JSON.stringify(printerConfigs, null, 2), 'utf8');
      res.json({ message: 'Printer deleted successfully' });
    } catch (error) {
      console.error('Error deleting printer:', error.message);
      res.status(500).json({ error: 'Failed to delete printer' });
    }
  });

  // Get single printer status
  router.get('/printer-status/:ip', async (req, res) => {
    try {
      const ip = req.params.ip;
      const printer = printerConfigs.find(p => p.ip === ip);
      if (!printer) {
        return res.status(404).json({ error: 'Printer not found' });
      }

      const status = await printerService.getPrinterStatus(printer, systemSettings.papercut);
      res.json(status);
    } catch (error) {
      console.error('Error getting printer status:', error);
      res.status(500).json({ message: 'Failed to get printer status', error: error.message });
    }
  });

// Get all printer statuses
router.get('/all-printer-status', async (req, res) => {
  try {
    console.log('Fetching all printer statuses');
    
    // 使用printerService获取真实的打印机状态
    const statuses = await printerService.getPrintersStatus(printerConfigs, systemSettings.papercut || {});
    
    console.log('Successfully fetched real printer statuses');
    console.log('Status data count:', statuses.length);
    
    // 返回真实的打印机状态数据
    res.json(statuses);
    console.log('Response successfully sent with real printer status data');
  } catch (error) {
    console.error('Error in all-printer-status endpoint:', error);
    // 错误情况下，返回一个包含错误信息的数组，而不是单个错误对象
    const errorStatuses = printerConfigs.map(printer => ({
      id: printer.id,
      name: printer.name,
      ip: printer.ip,
      status: 'Error',
      tonerLevels: {},
      paperStatus: 'Unknown',
      online: false,
      error: error.message || 'Failed to fetch printer status',
      source: 'error'
    }));
    res.status(200).json(errorStatuses); // 仍然返回200，前端可以处理status字段
  }
});

// Get remaining license days
router.get('/license-days', (req, res) => {
  // 从settingsService实时获取最新的许可证到期日期，确保使用用户在system settings中保存的值
  const expirationDateStr = settingsService.getLicenseExpirationDate();
  const expirationDate = new Date(expirationDateStr);
  const today = new Date();
  const days = Math.max(differenceInDays(expirationDate, today), 0);
  res.json({ remainingDays: days });
});

