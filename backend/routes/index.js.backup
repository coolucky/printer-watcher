router.get('/test-response', (req, res) => {
  res.json({ test: 'success', timestamp: new Date().toISOString() });
});

// Get local server metrics
router.get('/server-metrics', async (req, res) => {
  try {
    console.log('Request received for local server metrics:', new Date().toISOString());
    const serverMonitoringService = require('../services/serverMonitoringService');
    const metrics = await serverMonitoringService.getAllMetrics(req.query.useCache !== 'false');
    res.json({
      success: true,
      data: metrics,
      source: 'local'
    });
  } catch (error) {
    console.error('Error getting local server metrics:', error);
    res.status(500).json({
      success: false,
      error: error.message || 'Failed to get server metrics'
    });
  }
});

// Get remote server metrics
router.get('/remote-server-metrics/:ip', async (req, res) => {
  try {
    const { ip } = req.params;
    console.log(`Request received for remote server metrics for IP: ${ip}`, new Date().toISOString());
    
    // Validate IP address format
    const ipRegex = /^(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$/;
    if (!ipRegex.test(ip)) {
      return res.status(400).json({
        success: false,
        error: 'Invalid IP address format'
      });
    }
    
    const serverMonitoringService = require('../services/serverMonitoringService');
    const metrics = await serverMonitoringService.monitorRemoteServer(ip);
    
    res.json({
      success: true,
      data: metrics,
      source: 'remote'
    });
  } catch (error) {
    console.error(`Error getting remote server metrics for IP ${req.params.ip}:`, error);
    res.status(500).json({
      success: false,
      error: error.message || 'Failed to get remote server metrics'
    });
  }
});

module.exports = router;